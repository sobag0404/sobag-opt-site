{
  "name": "sobag-opt-site",
  "private": true,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:static": "node tools/static-server.mjs --port 4173",
    "dev:vercel": "npx -y vercel dev --listen 4173",
    "upload:photos": "node tools/bulk-upload-product-photos.mjs",
    "smoke:prod": "node tools/production-smoke.mjs",
    "smoke:prod:self-test": "node tools/production-smoke.mjs --self-test",
    "check": "node tools/autofix.mjs --check",
    "autofix": "node tools/autofix.mjs --write",
    "ui:smoke": "playwright test tools/ui-smoke.spec.js",
    "audit:catalog": "python tools/audit_catalog.py"
  },
  "dependencies": {
    "@upstash/redis": "^1.38.0",
    "@vercel/blob": "^2.4.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0"
  }
}
