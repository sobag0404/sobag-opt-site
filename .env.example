# Optional readiness-agent setting.
# Set to false to skip configured local verification commands during agent runs.
PROJECT_READINESS_RUN_COMMANDS=true

# Optional VPS object storage target. Keep real values in server/CI secrets only.
# VPS app/session data should use the local file store unless the server explicitly uses Redis.
SOBAG_STORE_PROVIDER=file
SOBAG_FILE_STORE_DIR=/var/lib/sobag-opt/store

# Product photo object storage remains S3-compatible until a separate filesystem media adapter exists.
SOBAG_OBJECT_STORAGE_PROVIDER=s3-compatible
SOBAG_S3_ENDPOINT=https://storage.example.test
SOBAG_S3_BUCKET=sobag-products
SOBAG_S3_REGION=auto
SOBAG_S3_ACCESS_KEY_ID=
SOBAG_S3_SECRET_ACCESS_KEY=
SOBAG_S3_SESSION_TOKEN=
SOBAG_S3_PUBLIC_BASE_URL=https://cdn.example.test/sobag-products
SOBAG_S3_FORCE_PATH_STYLE=true

# VPS/Rust cutover packet names only. Keep real values in VPS/CI secrets.
VPS_HOST=
VPS_USER=
VPS_SSH_KEY=
DATABASE_URL=
SOBAG_SESSION_SECRET=
SOBAG_JWT_SECRET=
SOBAG_ALLOWED_ORIGINS=https://sobag-shop.online
SOBAG_ADMIN_EMAIL=
SOBAG_ADMIN_PASSWORD=
